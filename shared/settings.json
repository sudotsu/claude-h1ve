{
  "autoMemoryDirectory": "~/h1ve/memory/claude",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '$HOME/h1ve/scripts/session-start.sh'",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '$HOME/h1ve/scripts/sync.sh'",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '$HOME/h1ve/scripts/sync.sh'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

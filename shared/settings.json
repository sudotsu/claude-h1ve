{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '$HOME/hive/scripts/session-start.sh'",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '$HOME/hive/scripts/sync.sh'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

# OS
.DS_Store
Thumbs.db

# Secrets — never commit these
*.env
*.key
*.pem
credentials.*

# Editor
.vscode/
.idea/
*.swp
*.swo

# Draft files — work-in-progress, never auto-synced
# Agents must write new files as <name>.md.draft until structurally complete,
# then rename to <name>.md. Prevents half-written handoffs or decisions
# from being committed and pushed by sync.sh on session end.
*.draft

# Scratch directory — temporary files, intermediate processing, test scripts
# All agents must use ~/h1ve/scratch/ for any throwaway work.
# Never write temp files to the repo root or any tracked directory.
scratch/

# Session history plugin (remember) — device-specific logs, not synced
# See machines/s25-termux/machine.md for documentation of this plugin.
.remember/
